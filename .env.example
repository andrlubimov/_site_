# ── Application ──────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com

# Domain used by the deploy script to generate the nginx config
DOMAIN=example.com

# Git repository URL (used by deploy.sh to clone the project)
REPO_URL=https://github.com/andrlubimov/swimming_association.git

# Root directory where the site will be deployed on the server
DEPLOY_DIR=/var/www/swimming_association

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=swimming_association
DB_USER=postgres
DB_PASSWORD=change_me
DB_HOST=127.0.0.1
DB_PORT=5432

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
# Set USE_S3=true to serve static and media files via MinIO/S3.
# Set USE_S3=false to serve them through nginx from the local filesystem.
USE_S3=false
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_BUCKET_NAME=swimming-association
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
